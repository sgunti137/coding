{
  ".cpp": {
    "compileCommand": [
      "g++",
      "${file}",
      "-o",
      "${fileDirname}/${fileBasenameNoExtension}"
    ],
    "runCommand": [
      "${fileDirname}/${fileBasenameNoExtension}"
    ]
  },
  ".py": {
    "runCommand": [
      "python",
      "${file}"
    ]
  },
  ".java": {
    "compileCommand": [
      "javac",
      "${file}"
    ],
    "runCommand": [
      "java",
      "-cp",
      "${fileDirname}",
      "${fileBasenameNoExtension}"
    ]
  }
}